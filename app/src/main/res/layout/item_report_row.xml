<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <EditText
            android:id="@+id/tvRecordNo"
            android:layout_width="60dp"
            android:layout_height="48dp"
            android:background="#F5F5F5"
            android:gravity="center"
            android:enabled="false"
            android:focusable="false"
            android:clickable="false"
            android:text="1"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCol1"
            android:layout_width="130dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Name"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol2"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="ID No"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol3"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Station"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol4"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Station No"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol5"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Issue"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol6"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Corrective Action"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol7"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Status"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCol8"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:hint="Remarks"
            android:padding="8dp" />

        <Button
            android:id="@+id/btnRemove"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:text="Remove"
            android:textAllCaps="false" />
    </LinearLayout>
</HorizontalScrollView>