<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvFormCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Form 1"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:textSize="16sp" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="Date"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:focusable="false"
            android:clickable="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Name"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp">

        <AutoCompleteTextView
            android:id="@+id/dropdownName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Id No"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp">

        <AutoCompleteTextView
            android:id="@+id/etIdNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Floor"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/dropdownFloor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Station"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/dropdownStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Station ID"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/etStationId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Issue"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/dropdownIssue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:maxLines="4"
            android:scrollHorizontally="false" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Corrective"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/etCorrective"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:maxLines="4"
            android:scrollHorizontally="false" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Status"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/dropdownStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Remark"
        app:boxBackgroundColor="@color/input_bg"
        app:boxStrokeColor="#2196F3"
        app:boxStrokeWidth="2dp">

        <AutoCompleteTextView
            android:id="@+id/etRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:maxLines="4"
            android:scrollHorizontally="false" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>