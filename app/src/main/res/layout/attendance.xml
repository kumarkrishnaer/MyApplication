<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="always"
    android:background="#F8FAFC">

    <LinearLayout
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER LOGO + DATE SHIFT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="130dp"
                android:layout_height="70dp"
                android:src="@drawable/team_logo"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end"
                android:paddingStart="10dp">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="29 Apr 2026"
                    android:textColor="#111827"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvShift"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shift: GN"
                    android:textColor="#6A11CB"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>

        <!-- ADD HEADER ROW -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_input_field"
            android:elevation="4dp"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etNewHeader"
                android:hint="Enter Attendance Header"
                android:background="@android:color/transparent"
                android:layout_weight="1"
                android:padding="8dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnAddHeader"
                android:text="+"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3B82F6"
                android:layout_marginStart="8dp"
                android:layout_width="48dp"
                android:layout_height="48dp" />
        </LinearLayout>

        <!-- HEADER DROPDOWN -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:hint="Select Attendance Header">

            <AutoCompleteTextView
                android:id="@+id/dropdownHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- HEADER DELETE CHIPS -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:singleLine="false"
            app:chipSpacing="6dp" />

        <!-- HIDE NAME SWITCH -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <Switch
                android:id="@+id/switchHideName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hide employee name"
                android:textSize="12sp"
                android:textColor="#444"
                android:layout_marginBottom="6dp" />
        </LinearLayout>

        <!-- EMPLOYEE INPUT -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_input_field"
            android:elevation="4dp"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etName"
                android:hint="Enter employee name"
                android:background="@android:color/transparent"
                android:layout_weight="1"
                android:padding="8dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnAdd"
                android:text="+"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3B82F6"
                android:layout_marginStart="8dp"
                android:layout_width="48dp"
                android:layout_height="48dp" />
        </LinearLayout>

        <!-- REMARK -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_input_field"
            android:elevation="4dp"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <EditText
                android:id="@+id/etRemark"
                android:hint="Remarks:-"
                android:background="@android:color/transparent"
                android:padding="6dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- STATS CARD -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/rounded"
            android:elevation="4dp"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="58dp">

            <TextView
                android:id="@+id/tvTotal"
                android:text="Total\n0"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvPresent"
                android:text="Present\n0"
                android:textColor="#22C55E"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvAbsent"
                android:text="Absent\n0"
                android:textColor="#EF4444"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvPercentage"
                android:text="0%"
                android:textColor="#F59E0B"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- PRESENT / ABSENT LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:layout_marginBottom="8dp" />

        <!-- SHARE BUTTON -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSharetask"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/bg_tri_color"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Share Via WhatsApp"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:includeFontPadding="false" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>