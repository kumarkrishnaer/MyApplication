<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:elevation="3dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="180dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADD DROPDOWN VALUES"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:textSize="20sp"
            android:gravity="center"
            android:padding="12dp" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Employee Details"
            android:textStyle="bold"
            android:textSize="20sp"

            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- NAME -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="3dp"
            android:background="@drawable/bg_shift_end_report"
            android:orientation="vertical">







            <AutoCompleteTextView
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:padding="5dp"
                android:layout_margin="5dp"


                android:layout_height="60dp"
                android:layout_weight="1"
                android:hint="Enter Name " />

            <AutoCompleteTextView
                android:id="@+id/etId"
                android:layout_width="match_parent"
                android:layout_margin="5dp"
                android:padding="5dp"

                android:layout_height="60dp"
                android:layout_weight="1"
                android:hint="Enter Id No" />

        </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:elevation="3dp"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddName"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="ADD"

                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteName"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />
            </LinearLayout>






        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Floor"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- FLOOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <AutoCompleteTextView
                android:id="@+id/etFloor"
                android:background="@drawable/bg_shift_end_report"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="5dp"
                android:padding="5dp"
                android:layout_weight="1"
                android:hint="Enter Floor" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFloor"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="ADD"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteFloor"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:textSize="11sp"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Station"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- STATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <AutoCompleteTextView
                android:id="@+id/etStation"
                android:padding="5dp"
                android:background="@drawable/bg_shift_end_report"
                android:layout_width="match_parent"
                android:layout_margin="5dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:hint="Enter Station" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStation"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="ADD"
                android:textSize="11sp"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteStation"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:textSize="11sp"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />

            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Station Id"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- STATION ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <AutoCompleteTextView
                android:id="@+id/etStationId"
                android:background="@drawable/bg_shift_end_report"
                android:layout_width="match_parent"
                android:layout_margin="5dp"
                android:layout_height="60dp"
                android:padding="5dp"
                android:layout_weight="1"
                android:hint="Enter Station ID" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStationId"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:text="ADD"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteStationId"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


        </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Issue &amp; Corrective Action"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- ISSUE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_shift_end_report"
            android:orientation="vertical">

            <AutoCompleteTextView
                android:id="@+id/etIssue"
                android:padding="5dp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_margin="2dp"

                android:hint="Enter Issue" />

            <AutoCompleteTextView
                android:id="@+id/etCorrective"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_margin="2dp"

                android:hint="Enter Corrective" />


        </LinearLayout>




            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddIssue"
                    android:layout_width="90dp"
                    android:layout_height="40dp"
                    android:text="ADD"
                    android:layout_marginLeft="5dp"
                    android:layout_marginBottom="5dp"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_shift_end_report_btn" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteIssue"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />

            </LinearLayout>




        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- STATUS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <AutoCompleteTextView
                android:id="@+id/etStatus"
                android:layout_width="match_parent"
                android:padding="5dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_shift_end_report"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:hint="Enter Status" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStatus"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="ADD"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteStatus"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />


        </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remarks"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textAlignment="viewStart"
            android:padding="5dp" />

        <!-- REMARK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <AutoCompleteTextView
                android:id="@+id/etRemark"
                android:layout_width="match_parent"
                android:padding="5dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_shift_end_report"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:hint="Enter Remark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddRemark"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="ADD"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />



            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteRemark"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:text="DEL"
                android:layout_marginLeft="5dp"
                android:layout_marginBottom="5dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:background="@drawable/bg_shift_end_report_btn" />
        </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>