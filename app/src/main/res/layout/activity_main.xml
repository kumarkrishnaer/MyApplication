<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/screen_bg">



        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginTop="20dp"
            android:background="@color/screen_bg">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:minHeight="0dp"
                android:padding="0dp" />

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/main_page_logo"
                android:scaleType="fitStart"
                android:adjustViewBounds="true"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageButton
                android:id="@+id/btnNotification"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_notifications"
                android:contentDescription="Notifications"
                app:tint="#6A11CB" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@color/surface_bg_runningtexy">



            <TextView
                android:id="@+id/tvRunningText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:textSize="16dp"
                android:textStyle="bold"
                android:textColor="@color/running_text"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:scrollHorizontally="true"/>
        </LinearLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/bannerViewPager"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_margin="16dp" />


        <!-- CONTENT -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:background="@color/screen_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="16dp">


                <!-- STATUS CARDS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="96dp"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="175dp"
                            android:minHeight="96dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:padding="14dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Today's Status"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tvTodayStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Not Updated"
                                android:textColor="@color/text_secondary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Last Update"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tvLastUpdate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No data"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>



                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="96dp"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="96dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:padding="14dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Logs"
                                android:layout_gravity="left"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"
                                android:paddingStart="12dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="4dp"/>

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/recyclerLog"
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:overScrollMode="never"
                                android:scrollbars="vertical"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- QUICK ACTIONS -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:padding="4dp"
                    android:useDefaultMargins="false">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnDownTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="112dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="112dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:gravity="center"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/home_ic_form"
                                android:adjustViewBounds="true" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="DT-TRAINING REPORT"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="8dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnattendanc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="112dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="112dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:gravity="center"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/ic_attendance"
                                android:adjustViewBounds="true" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Attendance"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="8dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnhrms"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="112dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="112dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:gravity="center"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/home_ic_support"
                                android:adjustViewBounds="true" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="HRMS"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="8dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnShiftEndReport"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="112dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="112dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:gravity="center"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/ic_shift_end_report"
                                android:adjustViewBounds="true" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Shift End Reports"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="8dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

<!--                    Traning report-->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnTraningDocs"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="112dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="112dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:gravity="center"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/ic_traningdocs"
                                android:adjustViewBounds="true" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Traning Docs "
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="8dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

<!--                    Analysis report-->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnAnalysisReport"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="112dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:minHeight="112dp"
                            android:orientation="vertical"
                            android:background="@drawable/rounded"
                            android:gravity="center"
                            android:padding="10dp">

                            <ImageView
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/ic_analysis"
                                android:adjustViewBounds="true" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Analysis Report "
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="8dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

                <!-- UPDATE BUTTON -->
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnUpdate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:contentDescription="Add"
                    android:layout_gravity="center_horizontal"
                    android:backgroundTint="#6A11CB"
                    app:srcCompat="@android:drawable/ic_input_add"
                    app:tint="@android:color/white" />

            </LinearLayout>

        </ScrollView>

        <!-- BOTTOM NAV -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            app:itemIconSize="24dp"
            android:background="@color/bottom_nav_bg"
            app:itemTextColor="@color/bottom_nav_color"
            app:itemIconTint="@color/bottom_nav_color"

            android:textColor="@color/text_primary"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_menu" />

    </LinearLayout>

    <!-- DRAWER -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/surface_bg">

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_bg"
            app:itemTextColor="@color/text_primary"
            app:itemIconTint="@color/text_primary"
            app:headerLayout="@layout/nav_header"
            app:menu="@menu/drawer_menu" />

        <LinearLayout
            android:id="@+id/themeSwitchLayout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:background="@color/surface_bg">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_dark_mode"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="28dp"
                android:text="Dark Mode"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:background="@color/surface_bg">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="#D32F2F" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>